{
  "name": "ai-producer-hub",
  "version": "1.0.0",
  "description": "AI Producer Hub - The Ultimate AI Music Production MCP Server. Mount Suno, VirtualDJ, Plex, Reaper, and OBS for cross-server AI music workflows.",
  "author": "Sandra",
  "license": "MIT",
  "repository": "https://github.com/sandraschi/ai-producer-hub",
  "tools": [
    "suno_to_deck",
    "ai_dj_set",
    "remix_plex_track",
    "bpm_bridge_generator",
    "live_stream_producer",
    "album_factory",
    "karaoke_generator",
    "ai_mashup",
    "hub_status",
    "producer_help"
  ],
  "entry": "src/ai_producer_hub/server.py",
  "python_version": ">=3.10",
  "dependencies": {
    "fastmcp": ">=2.13.0",
    "rich": ">=13.0.0"
  },
  "mounts": {
    "/dj": "virtualdj-mcp",
    "/plex": "plex-mcp",
    "/suno": "suno-mcp",
    "/reaper": "reaper-mcp",
    "/obs": "obs-mcp"
  }
}

